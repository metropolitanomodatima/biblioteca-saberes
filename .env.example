# OAuth App de GitHub (registrar en github.com/settings/developers)
# Callback URL local: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Organización y repositorio de GitHub
GITHUB_ORG=MODATIMA
GITHUB_REPO=biblioteca-saberes

# PAT fine-grained del bot con permisos: Contents write + Pull requests write
GITHUB_BOT_TOKEN=

# URL base del sitio (sin barra final)
# Local: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
SITE_URL=http://localhost:3000

# Secreto para firmar cookies de sesión (32 bytes aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Notificaciones de solicitud de acceso (resend.com — plan gratuito)
RESEND_API_KEY=
ADMIN_EMAIL=